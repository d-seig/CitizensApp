@page "/"

@using Web.Models;
@using DTO;

@rendermode InteractiveServer

@inject HttpClient Http
@inject IJSRuntime js

<PageTitle>Citizens</PageTitle>

<div class="container mt-4">
    <h3>Список жителей</h3>
    @if (apiResponse == null)
    {
        <p><em>Загрузка данных...</em></p>
    }
    else
    {
        <table class="table table-striped table-bordered">
            <thead class="table-dark">
                <tr>
                    <th style="cursor:pointer" @onclick='() => ChangeSort("Id")'>ID</th>
                    <th style="cursor:pointer" @onclick='() => ChangeSort("Famil")'>Фамилия</th>
                    <th style="cursor:pointer" @onclick='() => ChangeSort("Imja")'>Имя</th>
                    <th style="cursor:pointer" @onclick='() => ChangeSort("Otch")'>Отчество</th>
                    <th style="cursor:pointer" @onclick='() => ChangeSort("BirthDate")'>Дата рождения</th>
                    <th style="align-content:center">Опции</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var citizen in apiResponse.Items)
                {
                    <tr>
                        <td>@citizen.Id</td>
                        <td>@citizen.Famil</td>
                        <td>@citizen.Imja</td>
                        <td>@citizen.Otch</td>
                        <td>@citizen.BirthDate</td>
                        <td>
                            <NavLink class="btn btn-primary" href="@($"/edit/{@citizen.Id}")">Редактировать</NavLink>
                            <button class="btn btn-danger" @onclick='async () => await Delete(citizen)'>Удалить</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="mt-3">
            <button class="btn btn-sm btn-secondary" disabled="@(currentPage == 1)" @onclick="PrevPage">Назад</button>
            <span class="mx-2">Страница @currentPage/@totalPages</span>
            <button class="btn btn-sm btn-secondary" disabled="@(currentPage >= totalPages)" @onclick="NextPage">Вперед</button>
            <span class="mx-2">Строк на страницу: </span>
            <input type="number" min="1" max="50" @bind="pageSize" @bind:after="ChangePageSize" />
            <NavLink class="btn btn-primary" href="/create">Добавить нового</NavLink>
        </div>
    }
</div>

@code {

    private CitizenResponse apiResponse;
    private int currentPage = 1, 
                pageSize = 5,
                totalPages = 1;
    private string sortBy = "id";
    private bool Desc; // false

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        var url = $"api/citizens?sortBy={sortBy}&isDesc={Desc}&page={currentPage}&pageSize={pageSize}";
        if (Http.BaseAddress is null) Http.BaseAddress = new Uri("https://localhost:7286/");
        apiResponse = await Http.GetFromJsonAsync<CitizenResponse>(url);
        if (apiResponse is null)
        {
            currentPage = 1;
            totalPages = 1;
            return;
        }
        totalPages = (apiResponse.TotalCount + pageSize - 1) / pageSize;
    }

    private async Task PrevPage() { if (currentPage > 1) { currentPage--; await LoadData(); } }
    private async Task NextPage() 
    { 
        if (currentPage < totalPages) 
            currentPage++;
        await LoadData(); 
    }
    private async Task ChangePageSize()
    {
        totalPages = (apiResponse.TotalCount + pageSize - 1) / pageSize;
        if (currentPage > totalPages)
            currentPage = totalPages;
        await LoadData();
        StateHasChanged();
    }

    private async Task ChangeSort(string column)
    {
        sortBy = column;
        Desc = !Desc;
        await LoadData();
    }

    private async Task Delete(CitizenDTO citizen) 
    { 
        bool isConfirmed = await js.InvokeAsync<bool>("confirm", $"Вы уверены, что хотите удалить гражданина {citizen.Famil} {citizen.Imja}?");
        if (isConfirmed)
        {
            var response = await Http.DeleteAsync($"/api/citizens/{citizen.Id}");

            if (response.IsSuccessStatusCode)
                await LoadData();
            else
                await js.InvokeVoidAsync("alert", "Не удалось удалить запись на сервере.");
        }
    }  
}

